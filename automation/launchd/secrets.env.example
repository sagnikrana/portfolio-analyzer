# Copy to ~/.portfolio-analyzer/secrets.env and fill in. NEVER commit the real file.
# The launchd runner (run.sh) sources this before each job.

# --- Email delivery (Gmail example) ---
# For Gmail, create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=rana.sagnik05@gmail.com

# --- Local Ollama agent ---
# llama3.1:latest (fast) or llama3.3:latest (higher quality, slower)
OLLAMA_MODEL=llama3.1:latest
# OLLAMA_HOST=http://localhost:11434
